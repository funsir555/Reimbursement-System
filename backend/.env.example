FINEX_DB_URL=jdbc:mysql://localhost:3306/finex_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
FINEX_DB_USERNAME=root
FINEX_DB_PASSWORD=replace-with-your-db-password

FINEX_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

FINEX_AUTH_SERVICE_PORT=8081
FINEX_GATEWAY_PORT=8080
FINEX_AUTH_SERVICE_URL=http://localhost:8081

FINEX_LOG_LEVEL=info
FINEX_GATEWAY_LOG_LEVEL=info
FINEX_GATEWAY_FRAMEWORK_LOG_LEVEL=info
FINEX_MYBATIS_LOG_IMPL=org.apache.ibatis.logging.nologging.NoLoggingImpl

FINEX_ASYNC_CORE_POOL_SIZE=4
FINEX_ASYNC_MAX_POOL_SIZE=8
FINEX_ASYNC_QUEUE_CAPACITY=200
FINEX_ASYNC_THREAD_NAME_PREFIX=finex-async-
FINEX_ASYNC_AWAIT_TERMINATION_SECONDS=30
